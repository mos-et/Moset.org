{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Moset IDE",
  "version": "0.2.0",
  "identifier": "com.moset.ide",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Moset IDE - Motor Soberano",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' blob: data:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 Naraka Studio",
    "category": "DeveloperTool",
    "shortDescription": "Moset IDE — Motor Soberano de Desarrollo",
    "longDescription": "Entorno de desarrollo integrado para el lenguaje Moset con IA nativa (Motor Naraka), compilador bytecode, y ejecución cuántica.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["Spanish", "English"],
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://moset.org/api/update.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyREM4QTk0NUM1NUQ3MjcKUldRbjExVmNsSXJjTW5IOTNSK2VtRGwrVEpoU09Rbnh5RGpZT1hIa0hhN1pkajVzUys3cDZiUU4K"
    }
  }
}
